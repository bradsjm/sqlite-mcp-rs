# Core runtime
SQLITE_PERSIST_ROOT=
SQLITE_LOG_LEVEL=info

# SQL and import policy limits
SQLITE_MAX_SQL_LENGTH=20000
SQLITE_MAX_STATEMENTS=50
SQLITE_MAX_ROWS=500
SQLITE_MAX_BYTES=1048576
SQLITE_MAX_DB_BYTES=100000000

# Cursor pagination
SQLITE_CURSOR_TTL_SECONDS=600
SQLITE_CURSOR_CAPACITY=500

# Vector feature (required when running with --features vector)
SQLITE_EMBEDDING_PROVIDER=builtin
SQLITE_EMBEDDING_MODEL=
SQLITE_EMBEDDING_ENDPOINT=
SQLITE_EMBEDDING_SIZE=

# Optional reranker configuration (all required together when any is set)
SQLITE_RERANKER_PROVIDER=
SQLITE_RERANKER_MODEL=
SQLITE_RERANKER_ENDPOINT=
SQLITE_RERANKER_TIMEOUT_MS=10000
