# Core runtime
SQLITE_PERSIST_ROOT=
SQLITE_LOG_LEVEL=info

# SQL and import policy limits
SQLITE_MAX_SQL_LENGTH=20000
SQLITE_MAX_STATEMENTS=50
SQLITE_MAX_ROWS=100
SQLITE_MAX_BYTES=65536
SQLITE_MAX_DB_BYTES=100000000

# Cursor pagination
SQLITE_CURSOR_TTL_SECONDS=600
SQLITE_CURSOR_CAPACITY=500

# Vector feature (required when running with --features vector)
SQLITE_VECTOR_DIMENSION=384
SQLITE_MAX_VECTOR_TOP_K=200
SQLITE_MAX_RERANK_FETCH_K=500

# Local embeddings (when running with --features "vector local-embeddings")
SQLITE_EMBEDDING_PROVIDER=fastembed
SQLITE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
SQLITE_EMBEDDING_CACHE_DIR=

# Optional reranker configuration
SQLITE_RERANKER_PROVIDER=
SQLITE_RERANKER_MODEL=
SQLITE_RERANKER_CACHE_DIR=
